// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Auth (NextAuth) ─────────────────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Core Domain ─────────────────────────────────────────────────────────────

model Department {
  id   String @id @default(cuid())
  name String @unique
}

model Setting {
  key   String @id
  value String @db.Text
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  password      String?
  image         String?
  role          Role      @default(TEACHER)
  department    String?
  createdAt     DateTime  @default(now())

  accounts      Account[]
  sessions      Session[]
  bookings      Booking[]
  inventoryLogs InventoryLog[]
}

enum Role {
  ADMIN
  TEACHER
  PRINCIPAL
}

model Category {
  id          String  @id @default(cuid())
  name        String  @unique
  description String?
  color       String  @default("#3B82F6")
  icon        String  @default("package")

  assets Asset[]
}

model Asset {
  id                String      @id @default(cuid())
  name              String
  description       String?
  categoryId        String
  totalQuantity     Int         @default(0)
  availableQuantity Int         @default(0)
  unit              String      @default("cái")
  status            AssetStatus @default(AVAILABLE)
  imageUrl          String?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  category      Category       @relation(fields: [categoryId], references: [id])
  bookings      Booking[]
  inventoryLogs InventoryLog[]

  @@index([categoryId])
  @@index([status])
}

enum AssetStatus {
  AVAILABLE
  LOW_STOCK
  OUT_OF_STOCK
  DAMAGED
}

model Booking {
  id         String        @id @default(cuid())
  userId     String
  assetId    String
  quantity   Int
  borrowDate DateTime
  returnDate DateTime
  status     BookingStatus @default(PENDING)
  purpose    String?
  lesson     String?
  lessonName String?
  note       String?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  asset Asset @relation(fields: [assetId], references: [id])

  @@index([borrowDate])
  @@index([returnDate])
  @@index([status])
  @@index([userId])
  @@index([assetId])
}

enum BookingStatus {
  PENDING
  APPROVED
  REJECTED
  RETURNED
  CANCELLED
}

model InventoryLog {
  id              String    @id @default(cuid())
  assetId         String
  action          LogAction
  quantityChanged Int
  note            String?
  createdById     String
  createdAt       DateTime  @default(now())

  asset     Asset @relation(fields: [assetId], references: [id])
  createdBy User  @relation(fields: [createdById], references: [id])

  @@index([assetId])
  @@index([createdAt])
}

enum LogAction {
  IMPORT
  EXPORT
  DAMAGE
  REPAIR
  ADJUST
}
